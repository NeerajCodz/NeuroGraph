# NeuroGraph Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=neurograph
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=your-secret-key-change-in-production

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=debug
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,https://neurograph-ai.vercel.app
# CORS_ORIGIN_REGEX=

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_POOL_SIZE=50

# PostgreSQL
# Optional: use a full DSN instead of host/port/user/pass
DATABASE_URL=
POSTGRES_URI=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=neurograph
POSTGRES_PASSWORD=password
POSTGRES_DB=neurograph
POSTGRES_MIN_POOL_SIZE=5
POSTGRES_MAX_POOL_SIZE=20

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20

# Gemini API
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL_FLASH=gemini-2.0-flash
GEMINI_MODEL_PRO=gemini-2.0-pro
GEMINI_MODEL_EMBEDDING=models/gemini-embedding-2-preview

# NVIDIA API
NVIDIA_API_KEY=your-nvidia-api-key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Default LLM selection
DEFAULT_LLM_PROVIDER=nvidia
DEFAULT_LLM_MODEL=devstral-2-123b

# Groq API (Orchestrator)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Tavily API (Web Search)
TAVILY_API_KEY=your-tavily-api-key

# JWT Auth
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Memory Settings
MEMORY_DEFAULT_LAYER=personal
MEMORY_MAX_RESULTS=20
MEMORY_MIN_CONFIDENCE=0.5
MEMORY_DECAY_RATE=0.05
MEMORY_MAX_HOP_DEPTH=3

# RAG Settings
RAG_EMBEDDING_DIMENSION=768
RAG_SIMILARITY_THRESHOLD=0.7
RAG_MAX_CONTEXT_TOKENS=4000
RAG_GRAPH_BUDGET_TOKENS=2000
RAG_ASSET_BUDGET_TOKENS=800
RAG_INTEGRATION_BUDGET_TOKENS=600

# Scoring Weights
SCORING_SEMANTIC_WEIGHT=0.35
SCORING_HOP_WEIGHT=0.25
SCORING_CENTRALITY_WEIGHT=0.20
SCORING_TEMPORAL_WEIGHT=0.20

# MCP Settings
MCP_TRANSPORT=stdio
MCP_SESSION_TIMEOUT=3600

# Webhook Settings
WEBHOOK_SECRET=your-webhook-secret
WEBHOOK_TIMEOUT=30

# Slack Integration
SLACK_BOT_TOKEN=xoxb-your-slack-token
SLACK_SIGNING_SECRET=your-slack-signing-secret

# GitHub Integration
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret
GITHUB_APP_ID=your-app-id
GITHUB_PRIVATE_KEY_PATH=./github-app.pem

# Gmail Integration
GMAIL_PUBSUB_PROJECT_ID=your-gcp-project-id
GMAIL_PUBSUB_SUBSCRIPTION=neurograph-gmail-sub
